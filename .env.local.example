# ─────────────────────────────────────────
# Supabase — get these from your project:
# supabase.com → Project Settings → API
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Secret key — SERVER ONLY, never use in frontend code
# Supabase > Project Settings > API > Secret keys > Reveal
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY_HERE

# Order notification email (Resend — free at resend.com)
RESEND_API_KEY=re_YOUR_KEY_HERE

# Your email — where order notifications get sent
ADMIN_EMAIL=your@email.com

# Same email exposed to the browser for client-side admin gate (must match ADMIN_EMAIL)
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# Optional: verified sender email in Resend (defaults to onboarding@resend.dev for dev)
# RESEND_FROM_EMAIL=orders@northhillsystems.com

# Your site URL (used in admin email links)
NEXT_PUBLIC_SITE_URL=https://northhillsystems.com
